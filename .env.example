# M0-04 baseline compose env

# Redis
REDIS_PORT=6379

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=arco_user
POSTGRES_PASSWORD=arco_password
POSTGRES_DB=arco_db

# Python Web metadata DB (PostgreSQL baseline)
DATABASE_URL=postgresql+psycopg2://arco_user:arco_password@127.0.0.1:5432/arco_db

# VictoriaMetrics
VM_PORT=8428
VM_RETENTION_PERIOD=3
