# Flask 配置
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True

# 密钥（生产环境必须修改！）
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 数据库
DATABASE_URL=sqlite:///it_ops.db

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Go Manager API（M3-01）
GO_MANAGER_URL=http://127.0.0.1:8080
GO_MANAGER_TIMEOUT_SECONDS=3
GO_MANAGER_MAX_RETRIES=2
GO_MANAGER_CB_FAILURE_THRESHOLD=3
GO_MANAGER_CB_RECOVERY_SECONDS=30
