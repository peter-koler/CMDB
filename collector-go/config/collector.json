{
  "server": {
    "addr": ":50051"
  },
  "scheduler": {
    "tick_ms": 1000,
    "wheel_size": 512
  },
  "worker": {
    "size": 8,
    "queue_size": 2048
  },
  "queue": {
    "backend": "memory",
    "memory": {
      "size": 4096
    },
    "kafka": {
      "brokers": ["127.0.0.1:9092"],
      "topic": "collector.metrics",
      "bin": "kcat"
    }
  },
  "stream": {
    "heartbeat_ms": 10000
  }
}
